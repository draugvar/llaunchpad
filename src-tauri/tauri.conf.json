{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Llaunchpad",
  "version": "0.7.0",
  "identifier": "com.draugvar.llaunchpad",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Llaunchpad",
        "width": 560,
        "height": 720,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/AppIcon.icns"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Launch any Ollama coding agent against any cloud model",
    "longDescription": "Llaunchpad is a tiny, good-looking GUI that picks the agent (Codex, Claude Code, Cursor, …) and the cloud model, then runs `ollama launch <agent> --model <model>` for you in one click.",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
